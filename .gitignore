.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Ruff cache
.ruff_cache/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS artefacts
.DS_Store
Thumbs.db

# Node (frontend)
web/node_modules/
web/dist/
web/.vite/

