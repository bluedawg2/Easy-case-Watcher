# Copy this file to .env and fill in real values.
# The .env file is git-ignored and MUST NOT be committed.

# PostgreSQL connection string for the main application database.
# Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg://brm:brm@localhost:5432/brm

# Anthropic API key for LLM-powered change summarization.
ANTHROPIC_API_KEY=sk-ant-...

# Shared API key for the review-queue and pull-delivery APIs.
# Used as the X-API-Key header value — at least 32 random characters recommended.
API_KEY=change-me-to-a-random-secret
